func flattenScheduling(resp map[string]interface{}) []map[string]interface{} {
	if resp == nil {
		return nil
	}
	schedulingMap := map[string]interface{}{
		"on_host_maintenance":         resp["onHostMaintenance"],
		"preemptible":                 resp["preemptible"],
		"provisioning_model":          resp["provisioningModel"],
		"instance_termination_action": resp["instanceTerminationAction"],
		"termination_time":            resp["terminationTime"],
	}

	if v, ok := resp["minNodeCpus"].(float64); ok {
		schedulingMap["min_node_cpus"] = int64(v)
	} else {
		schedulingMap["min_node_cpus"] = int64(0)
	}

	if v, ok := resp["availabilityDomain"].(float64); ok {
		schedulingMap["availability_domain"] = int64(v)
	} else {
		schedulingMap["availability_domain"] = int64(0)
	}

	if autoRestart, ok := resp["automaticRestart"].(bool); ok {
		schedulingMap["automatic_restart"] = autoRestart
	}

	if maxRunDuration, ok := resp["maxRunDuration"].(map[string]interface{}); ok {
		schedulingMap["max_run_duration"] = flattenComputeMaxRunDuration(maxRunDuration)
	}

	if onInstanceStopAction, ok := resp["onInstanceStopAction"].(map[string]interface{}); ok {
		schedulingMap["on_instance_stop_action"] = flattenOnInstanceStopAction(onInstanceStopAction)
	}

{{ if ne $.TargetVersionName `ga` -}}
	schedulingMap["skip_guest_os_shutdown"] = resp["skipGuestOsShutdown"]

	if v, ok := resp["hostErrorTimeoutSeconds"].(float64); ok && v != 0 {
		schedulingMap["host_error_timeout_seconds"] = int64(v)
	}

	if maintenanceInterval, ok := resp["maintenanceInterval"].(string); ok && maintenanceInterval != "" {
		schedulingMap["maintenance_interval"] = maintenanceInterval
	}

	if gracefulShutdown, ok := resp["gracefulShutdown"].(map[string]interface{}); ok {
		schedulingMap["graceful_shutdown"] = flattenGracefulShutdown(gracefulShutdown)
	}

	if preemptionNoticeDuration, ok := resp["preemptionNoticeDuration"].(map[string]interface{}); ok {
		schedulingMap["preemption_notice_duration"] = flattenComputePreemptionNoticeDuration(preemptionNoticeDuration)
	}
{{- end }}

	if localSsdRecoveryTimeout, ok := resp["localSsdRecoveryTimeout"].(map[string]interface{}); ok {
		schedulingMap["local_ssd_recovery_timeout"] = flattenComputeLocalSsdRecoveryTimeout(localSsdRecoveryTimeout)
	}

	nodeAffinities := schema.NewSet(schema.HashResource(instanceSchedulingNodeAffinitiesElemSchema()), nil)
	if naList, ok := resp["nodeAffinities"].([]interface{}); ok {
		for _, raw := range naList {
			na, _ := raw.(map[string]interface{})
			values, _ := na["values"].([]interface{})
			nodeAffinities.Add(map[string]interface{}{
				"key":      na["key"].(string),
				"operator": na["operator"].(string),
				"values":   schema.NewSet(schema.HashString, values),
			})
		}
	}
	schedulingMap["node_affinities"] = nodeAffinities

	return []map[string]interface{}{schedulingMap}
}

